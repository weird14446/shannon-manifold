# Copy this file to `.env` and edit values for your local or deployed environment.

# Shared application settings
CHATBOT_MODEL=gpt-4o
CHATBOT_PROVIDER=mock
CHATBOT_API_BASE_URL=https://api.openai.com/v1
CHATBOT_API_KEY=
CHATBOT_SYSTEM_PROMPT=You are Shannon Manifold Oracle, a precise assistant for proofs, Lean4, Rocq, and theorem debugging.
CHATBOT_TEMPERATURE=0.2
CHATBOT_TIMEOUT_SECONDS=45
CHATBOT_MAX_HISTORY_MESSAGES=12
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=change-this-secret-key-before-production-1234
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
PROOF_UPLOAD_DIR=/app/storage/uploads
PROOF_ARTIFACT_DIR=/app/storage/artifacts
LEAN_WORKSPACE_DIR=/workspace/lean-workspace
LEAN_PLAYGROUND_FILE=ShannonManifold/Playground.lean
LEAN_REPOSITORY_SUBDIR=lean-workspace

# MySQL settings for local Docker development
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=shannon_manifold
MYSQL_USER=shannon_app
MYSQL_PASSWORD=shannon_password
MYSQL_ROOT_PASSWORD=root_password

# Optional explicit database URL override, useful for AWS RDS
# DATABASE_URL=mysql+pymysql://user:password@host:3306/shannon_manifold

# Frontend runtime configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_LEAN_WS_URL=ws://localhost:8080/
GITHUB_REPOSITORY_URL=https://github.com/owner/repository
GITHUB_REPOSITORY_BRANCH=main
GITHUB_ACCESS_TOKEN=
GITHUB_COMMIT_AUTHOR_NAME=Shannon Manifold Bot
GITHUB_COMMIT_AUTHOR_EMAIL=bot@shannon-manifold.local
VITE_GITHUB_REPOSITORY_URL=https://github.com/owner/repository
