{
  "name": "Shannon Manifold Dev Environment",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/shannon-manifold",
  "mounts": [
    "source=shannon-manifold-frontend-node_modules,target=${containerWorkspaceFolder}/frontend/node_modules,type=volume"
  ],
  "postCreateCommand": "pip3 install -r backend/requirements.txt && npm ci --prefix frontend",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "remoteUser": "root",
  "forwardPorts": [8000, 5173]
}
